{
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "fcrespo82.markdown-table-formatter"
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports": "always"
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnType": true
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "bashIde.explainshellEndpoint": "http://localhost:5000",
  "chat.agent.enabled": true,
  "chat.extensionTools.enabled": true,
  "chat.mcp.access": "all",
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "cursor-global": true,
    "cursor-workspace": true,
    "windsurf": true
  },
  "chat.promptFilesLocations": {
    "prompts": true
  },
  "chat.tools.autoApprove": false,
  "editor.codeActionsOnSave": {
    "source.addMissingImports": "always",
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "emeraldwalk.runonsave": {},
  "evenBetterToml.formatter.alignEntries": true,
  "evenBetterToml.formatter.indentString": "  ",
  "evenBetterToml.formatter.indentTables": true,
  "evenBetterToml.schema.associations": {
    "^(.*(/|\\)\\.?taplo\\.toml|\\.?taplo\\.toml)$": "taplo://taplo.toml"
  },
  "evenBetterToml.schema.links": true,
  "files.associations": {
    "*.chatmode.md": "markdown",
    "*.hcl": "terraform",
    "*.ini": "ini",
    "*.instructions.md": "markdown",
    "*.kiro.hook": "json",
    "*.md": "markdown",
    "*.prompt.md": "markdown",
    "*.sh": "shellscript",
    "*.tf": "terraform",
    "*.tofu": "opentofu",
    "*.toml": "toml",
    ".style.yapf": "ini",
    ".terraformrc": "hcl",
    "Brewfile*": "ruby",
    "Dockerfile*": "dockerfile",
    "config": "ini"
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.alwaysSignOff": true,
  "git.autoStash": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.copilotDebugCommand.enabled": false,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.reviewSelection.instructions": [],
  "github.copilot.enable": {
    "*": true,
    "apex": true,
    "erb": true,
    "go": true,
    "java": true,
    "javascript": true,
    "markdown": false,
    "plaintext": false,
    "python": true,
    "ruby": true,
    "rust": true,
    "scala": true,
    "scminput": false,
    "shellscript": true,
    "starlark": true,
    "terraform": true,
    "typescript": true,
    "typescriptreact": true
  },
  "githubIssues.queries": [
    {
      "label": "My Issues",
      "query": "default"
    },
    {
      "label": "Created Issues",
      "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
    },
    {
      "label": "Recent Issues",
      "query": "state:open repo:${owner}/${repository} sort:updated-desc"
    }
  ],
  "gitlens.autolinks": [],
  "json.schemas": [
    {
      "fileMatch": [
        ".golangci.yml"
      ],
      "url": "https://golangci-lint.run/jsonschema/golangci.jsonschema.json"
    },
    {
      "fileMatch": [
        "*.dd.json"
      ],
      "url": "https://raw.githubusercontent.com/DataDog/datadog-cloudformation-resources/master/datadog-monitors-monitor-handler/datadog-monitors-monitor.json"
    },
    {
      "fileMatch": [
        "*taskdef.json"
      ],
      "url": "https://ecs-intellisense.s3-us-west-2.amazonaws.com/task-definition/schema.json"
    },
    {
      "fileMatch": [
        ".prettierrc",
        "prettier.config.js"
      ],
      "url": "https://www.schemastore.org/prettierrc"
    }
  ],
  "kiroAgent.agentAutonomy": "Autopilot",
  "kiroAgent.enableCodebaseIndexing": true,
  "kiroAgent.enableTabAutocomplete": true,
  "kiroAgent.modelSelection": "auto",
  "kiroAgent.notifications.agent.actionRequired": true,
  "kiroAgent.notifications.agent.failure": true,
  "kiroAgent.notifications.agent.success": true,
  "kiroAgent.trustedCommands": [
    "aube *",
    "aubr *",
    "aubx *",
    "cat *",
    "curl *",
    "find *",
    "go build *",
    "go test *",
    "go vet *",
    "gofumpt *",
    "golangci-lint run *",
    "golines *",
    "grep *",
    "hk *",
    "make *",
    "npm *",
    "npx *",
    "pnpm *",
    "pnpx *",
    "sed *",
    "tail *",
    "task *",
    "wc *",
    "wget *"
  ],
  "kiroAgent.usageSummary": true,
  "makefile.configureOnOpen": false,
  "markdown-table-formatter.markdownGrammarScopes": [
    "markdown",
    "gohtml",
    "gotmpl"
  ],
  "markdown-table-formatter.removeColonsIfSameAsDefault": true,
  "markdown.extension.list.indentationSize": "inherit",
  "markdown.extension.orderedList.marker": "one",
  "markdown.extension.tableFormatter.normalizeIndentation": true,
  "markdown.extension.toc.levels": "1..6",
  "markdown.extension.toc.unorderedList.marker": "*",
  "markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', 'Ubuntu', 'Droid Sans', sans-serif",
  "markdown.updateLinksOnFileMove.enabled": "always",
  "notebook.defaultFormatter": "yzhang.markdown-all-in-one",
  "prettier.proseWrap": "never",
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.typeEvaluation.deprecateTypingAliases": true,
  "python.defaultInterpreterPath": "python3",
  "python.languageServer": "Pylance",
  "python.missingPackage.severity": "Information",
  "python.pythonPath": "${workspaceFolder}/.venv/",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "pythonTestExplorer.testFramework": "pytest",
  "remote.defaultExtensionsIfInstalledLocally": [
    "GitHub.copilot",
    "GitHub.copilot-chat",
    "GitHub.vscode-pull-request-github"
  ],
  "rewrap.autoWrap.enabled": false,
  "sarif-viewer.connectToGithubCodeScanning": "off",
  "shellcheck.enableQuickFix": true,
  "shellformat.effectLanguages": [
    "azcli",
    "bats",
    "dotenv",
    "gitignore",
    "hosts",
    "ignore",
    "jvmoptions",
    "properties",
    "shellscript",
    "spring-boot-properties"
  ],
  "shellformat.flag": "-s -ln=bash -i=4 -ci -sr",
  "shellformat.useEditorConfig": true,
  "snyk.advanced.autoScanOpenSourceSecurity": true,
  "snyk.advanced.autoSelectOrganization": true,
  "testExplorer.useNativeTesting": true,
  "todo-tree.general.tags": [
    "BUG",
    "HACK",
    "FIXME",
    "TODO",
    "XXX",
    "[ ]",
    "[x]"
  ],
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.ipynb": "jupyter-notebook",
    "*.svg": "default",
    "git-rebase-todo": "default",
    "{git,gitlens,conflictResolution,vscode-local-history}:/**/*.tc.json": "default"
  },
  "yaml.schemas": {
    "https://goreleaser.com/static/schema-pro.json": ".goreleaser.yml"
  },
  "yaml.validate": false,
  "yapf.args": [
    "-i",
    "*.py"
  ]
}
