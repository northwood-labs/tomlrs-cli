{
  "name": "kirograph",
  "description": "KiroGraph-aware agent — semantic code graph for symbol lookup, call graphs, impact analysis, architecture metrics. Workflow steering files are registered as resources — activate one with /kirograph-review, /kirograph-debug, /kirograph-architecture, /kirograph-onboard, /kirograph-refactor.",
  "resources": [
    "file://.kiro/steering/kirograph.md",
    "file://.kiro/steering/kirograph-review.md",
    "file://.kiro/steering/kirograph-debug.md",
    "file://.kiro/steering/kirograph-onboard.md",
    "file://.kiro/steering/kirograph-refactor.md",
    "file://.kiro/steering/kirograph-architecture.md"
  ],
  "tools": [
    "@builtin",
    "@kirograph"
  ],
  "allowedTools": [
    "@kirograph/kirograph_search",
    "@kirograph/kirograph_context",
    "@kirograph/kirograph_callers",
    "@kirograph/kirograph_callees",
    "@kirograph/kirograph_impact",
    "@kirograph/kirograph_node",
    "@kirograph/kirograph_status",
    "@kirograph/kirograph_files",
    "@kirograph/kirograph_dead_code",
    "@kirograph/kirograph_circular_deps",
    "@kirograph/kirograph_path",
    "@kirograph/kirograph_architecture",
    "@kirograph/kirograph_coupling",
    "@kirograph/kirograph_package",
    "@kirograph/kirograph_hotspots",
    "@kirograph/kirograph_surprising",
    "@kirograph/kirograph_diff",
    "@kirograph/kirograph_type_hierarchy",
    "@kirograph/kirograph_exec",
    "@kirograph/kirograph_gain",
    "@kirograph/kirograph_read",
    "@kirograph/kirograph_budget",
    "@kirograph/kirograph_flows",
    "@kirograph/kirograph_communities",
    "@kirograph/kirograph_refactor",
    "@kirograph/kirograph_mem_search",
    "@kirograph/kirograph_mem_store",
    "@kirograph/kirograph_mem_timeline",
    "@kirograph/kirograph_mem_status",
    "@kirograph/kirograph_docs_toc",
    "@kirograph/kirograph_docs_search",
    "@kirograph/kirograph_docs_section",
    "@kirograph/kirograph_docs_outline",
    "@kirograph/kirograph_docs_refs",
