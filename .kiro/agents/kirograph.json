    "@kirograph/kirograph_data_describe",
    "@kirograph/kirograph_data_query",
    "@kirograph/kirograph_data_aggregate",
    "@kirograph/kirograph_data_search",
    "@kirograph/kirograph_data_join",
    "@kirograph/kirograph_data_correlations",
    "@kirograph/kirograph_data_quality",
    "@kirograph/kirograph_security",
    "@kirograph/kirograph_vulns",
    "@kirograph/kirograph_sbom",
    "@kirograph/kirograph_vex",
    "@kirograph/kirograph_reachability",
    "@kirograph/kirograph_vuln_add",
    "@kirograph/kirograph_vuln_suppress",
    "@kirograph/kirograph_staleness",
    "@kirograph/kirograph_licenses",
    "@kirograph/kirograph_attack_surface",
    "@kirograph/kirograph_secrets",
    "@kirograph/kirograph_security_flows",
    "@kirograph/kirograph_supply_chain",
