{
  "cavemanMode": "lite",
  "dataContextLimit": 0,
  "dataExclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**",
    "**/package-lock.json",
    "**/yarn.lock",
    "**/pnpm-lock.yaml",
    "**/tsconfig.json",
    "**/jsconfig.json",
    "coverage/**",
    "**/generated/**"
  ],
  "dataInclude": [
    "**/*.csv",
    "**/*.tsv",
    "**/*.jsonl",
    "**/*.ndjson",
    "**/*.xlsx",
    "**/*.xls",
    "**/*.parquet",
    "data/**/*.json"
  ],
  "dataLinkCode": true,
  "dataMaxFileSize": 52428800,
  "dataMaxResponseTokens": 8000,
  "dataMaxRows": 1000000,
  "dataQueryLimit": 500,
  "docsContextLimit": 0,
  "docsContextThreshold": 0.3,
  "docsExclude": [
    "node_modules/**",
    "**/CHANGELOG*",
    "**/LICENSE*",
    "**/CHANGES*",
    "dist/**",
    "build/**",
    "coverage/**",
    ".git/**",
    "**/generated/**",
    "**/auto-generated/**",
    "**/vendor/**",
    "_build/**"
  ],
  "docsInclude": [
    "**/*.md",
    "**/*.mdx",
    "**/*.rst",
    "**/*.adoc",
    "**/*.asciidoc",
    "**/*.rdoc",
    "**/*.org",
    "**/*.cheatmd",
    "docs/**/*.txt",
    "docs/**/*.html"
  ],
  "docsLinkCode": true,
  "docsMaxFileSize": 1048576,
  "docsSummarization": "first-sentence",
  "embeddingDim": 768,
  "embeddingModel": "nomic-ai/nomic-embed-text-v1.5",
  "enableArchitecture": true,
  "enableData": false,
  "enableDocs": false,
  "enableEmbeddings": true,
  "enableMemory": false,
  "enableSecurity": false,
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "*.min.js",
    "**/.kirograph/**"
  ],
  "extractDocstrings": true,
  "frameworkHints": [],
  "fuzzyResolutionThreshold": 0.5,
  "include": [],
  "languages": [],
  "maxFileSize": 1048576,
  "memoryContextLimit": 3,
  "memoryContextThreshold": 0.3,
  "memoryExcludePatterns": [],
  "memoryKeepRaw": false,
  "memoryMaxObservations": 10000,
  "memorySearchAlpha": 0.5,
  "memorySessionTimeout": 7200,
  "minLogLevel": "warn",
  "qdrantDashboard": false,
  "securityAutoEnrich": true,
  "securityDatabases": [
    "OSV"
  ],
  "securityEnrichMaxAgeDays": 7,
  "securityLicensePolicy": {
    "deny": [],
    "warn": []
  },
  "semanticEngine": "cosine",
  "shellCompressionLevel": "normal",
  "syncWarningThreshold": 10,
  "trackCallSites": true,
  "typesenseDashboard": false,
  "useVecIndex": false,
  "version": 2
}
